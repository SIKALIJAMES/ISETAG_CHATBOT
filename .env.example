# =============================================
# ISETAG CHATBOT V2 — Configuration
# =============================================

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=isetag_v2_verify_2025

# Facebook Messenger Platform API
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=isetag_messenger_verify_2025

# Google Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Database (Neon PostgreSQL + pgvector)
DATABASE_URL=

# Cache & Session (Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Security
JWT_SECRET=
PHONE_SALT=
ADMIN_EMAIL=admin@isetag.cm
ADMIN_PASSWORD_HASH=

# Server
PORT=3000
NODE_ENV=development

# Public URL (used for pre-registration form links in WhatsApp messages)
# Set this to your Railway/production domain, e.g. https://isetag-chatbot.railway.app
APP_URL=https://isetag-chatbot.railway.app
