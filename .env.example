# =============================================
# ISETAG CHATBOT — Environment Variables
# =============================================
# Copy this file to .env and fill in the values

# ------------------------------------------
# WhatsApp (Meta Sandbox / Cloud API)
# ------------------------------------------
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_sandbox_permanent_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_APP_SECRET=your_app_secret_here
# Custom verify token — you create this string (anything)
WHATSAPP_VERIFY_TOKEN=isetag_verify_token_2025

# ------------------------------------------
# OpenAI (GPT-4o-mini + Whisper)
# ------------------------------------------
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ------------------------------------------
# Database (Railway PostgreSQL)
# ------------------------------------------
# Get from: Railway.app → Your Project → PostgreSQL → Connect
DATABASE_URL=postgresql://user:password@host.railway.app:5432/railway

# ------------------------------------------
# Redis (Upstash Free Tier — REST API)
# ------------------------------------------
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token-here

# ------------------------------------------
# JWT Authentication
# ------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_very_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=8h

# ------------------------------------------
# App Configuration
# ------------------------------------------
PORT=3000
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_SALT=another_random_secret_for_phone_hashing

# Admin WhatsApp number for escalation alerts (with country code)
ADMIN_WHATSAPP_NUMBER=+237600000000

# ------------------------------------------
# V2 ONLY — Leave empty for V1
# ------------------------------------------
FACEBOOK_PAGE_ACCESS_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
